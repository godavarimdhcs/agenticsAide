{
  "name": "Lakehouse Default Cluster Policy",
  "description": "Baseline policy for all data platform clusters. Enforces cost controls, Unity Catalog, and secure networking.",
  "definition": {
    "spark_version": {
      "type": "allowlist",
      "values": [
        "14.3.x-scala2.12",
        "14.3.x-photon-scala2.12",
        "15.4.x-scala2.12"
      ],
      "defaultValue": "14.3.x-scala2.12"
    },
    "node_type_id": {
      "type": "allowlist",
      "values": [
        "Standard_DS3_v2",
        "Standard_DS4_v2",
        "Standard_DS5_v2",
        "Standard_E8ds_v4",
        "Standard_E16ds_v4"
      ],
      "defaultValue": "Standard_DS3_v2"
    },
    "autotermination_minutes": {
      "type": "range",
      "minValue": 10,
      "maxValue": 120,
      "defaultValue": 30
    },
    "num_workers": {
      "type": "range",
      "minValue": 1,
      "maxValue": 16
    },
    "data_security_mode": {
      "type": "fixed",
      "value": "SINGLE_USER"
    },
    "runtime_engine": {
      "type": "allowlist",
      "values": ["STANDARD", "PHOTON"],
      "defaultValue": "STANDARD"
    },
    "spark_conf.spark.databricks.cluster.profile": {
      "type": "fixed",
      "value": "serverless"
    },
    "spark_conf.spark.databricks.repl.allowedLanguages": {
      "type": "fixed",
      "value": "python,sql"
    },
    "custom_tags.team": {
      "type": "regex",
      "pattern": "[a-z0-9\\-]+"
    },
    "custom_tags.env": {
      "type": "allowlist",
      "values": ["dev", "qa", "prod"]
    },
    "custom_tags.cost_center": {
      "type": "regex",
      "pattern": "CC-[0-9]{4}"
    }
  }
}
